#include <stdio.h>

/**
 * _isupper - checks if the character is in uppercase or not
 * @c: character to be checked
 *
 * Return: 1 if uppercase, 0 otherwise
 */
int _isupper(int c)
{
	if (c >= 65 && c <= 90)
		return (1);
	else
		return (0);
}

