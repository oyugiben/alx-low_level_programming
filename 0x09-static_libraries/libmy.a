#include <stdio.h>

/**
 * _isalpha - checks if the character is an alphabet
 * @c: input character to be checked
 *
 * Return: 1 if c is an alphabet else return 0
 */
int _isalpha(int c)
{
	if (c >= 65 && c <= 90)
		return (1);
	else if (c >= 97 && c <= 122)
		return (1);
	else
		return (0);
}
